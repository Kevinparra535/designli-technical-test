# Copy to .env and fill in. Used by `npm run dev` and docker-compose.

# Server
NODE_ENV=development
PORT=3000

# PostgreSQL — either set DATABASE_URL, or the discrete PG* parts below.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/stocks
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=stocks

# Auth — CHANGE THIS in production.
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# Finnhub (server-side key — get a free one at https://finnhub.io/dashboard)
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_WS_URL=wss://ws.finnhub.io
FINNHUB_API_KEY=

# Real-time price hub. true = 1 upstream WS to Finnhub fanned out to app clients
# (path WS_PATH) + alerts evaluated inline. false = fall back to the polling worker.
STREAMING_ENABLED=true
WS_PATH=/ws
PRICE_THROTTLE_MS=400

# Firebase Cloud Messaging — provide ONE of:
#  - GOOGLE_APPLICATION_CREDENTIALS: absolute path to serviceAccount.json
#  - FIREBASE_SERVICE_ACCOUNT: the full JSON on one line (handy in containers)
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT=

# Alert evaluation worker
POLL_INTERVAL_MS=15000
ALERT_WORKER_ENABLED=true
