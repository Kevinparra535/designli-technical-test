# Copy to .env and fill in. In Expo, ONLY EXPO_PUBLIC_* vars reach the app bundle.

# Finnhub — get a free key at https://finnhub.io/dashboard
EXPO_PUBLIC_FINNHUB_BASE_URL=https://finnhub.io/api/v1
EXPO_PUBLIC_FINNHUB_API_KEY=

# Webhook backend (optional)
EXPO_PUBLIC_WEBHOOK_BASE_URL=
EXPO_PUBLIC_WEBHOOK_API_KEY=
